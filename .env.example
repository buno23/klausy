# ─── Klausy API-Konfiguration ───
# Kopiere diese Datei zu .env und trage deine eigenen Keys ein:
#   cp .env.example .env
#
# Hol dir einen Key z.B. bei:
# - OpenAI:    https://platform.openai.com/api-keys
# - GPUStack:  (dein lokaler LLM-Anbieter)

OPENAI_API_KEY=dein_api_key_hier_eintragen
DISCORD_TOKEN=dein_discord_token_hier_eintragen
